# Docker host port. Container still listens on 9876.
DICEFRAME_HTTP_PORT=9876

# LLM provider. Leave blank and configure in WebUI if preferred.
TRPG_LLM_API_KEY=
TRPG_LLM_BASE_URL=
TRPG_LLM_MODEL=

# Optional fixed WebUI login token. Leave blank to auto-generate into data/access_token.txt.
TRPG_ACCESS_TOKEN=

# Optional HTTP proxy, for example http://host.docker.internal:7890
TRPG_PROXY_URL=

# Optional QQ / NapCat plugin settings. Leave blank and configure in WebUI if preferred.
# If NapCat runs on the same Linux host outside Docker, host.docker.internal is mapped
# by docker-compose.yml; a real LAN IP also works.
TRPG_BOT_TOKEN=
NAPCAT_HOST=
NAPCAT_PORT=
NAPCAT_TOKEN=
